# =============================================
# Frontend Environment Variables (Vite)
# Copy to frontend/.env.local for local dev
# =============================================

VITE_API_BASE_URL=https://your-api-id.execute-api.ap-northeast-2.amazonaws.com/prod
VITE_COGNITO_USER_POOL_ID=ap-northeast-2_XXXXXXXXX
VITE_COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_REGION=ap-northeast-2

# =============================================
# Backend Environment Variables (Lambda)
# Set these in serverless.yml or CDK stack
# =============================================

AWS_REGION=ap-northeast-2
DYNAMODB_TABLE_PREFIX=quiz-app
S3_PDF_BUCKET=quiz-app-pdfs-your-account-id
COGNITO_USER_POOL_ID=ap-northeast-2_XXXXXXXXX
